{
  "name": "Siimit",
  "version": "0.16.1",
  "description": "A CLI for logging and submitting training jobs",
  "type": "module",
  "author": {
    "name": "MugeTong",
    "email": "here5320@gmail.com"
  },
  "license": "MIT",
  "readme": "README.md",
  "bin": {
    "siimit": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build --compile --minify --target bun-linux-x64 src/index.ts --outfile dist/siimit-linux-x86_64",
    "package": "xz -3 -f dist/siimit-linux-x86_64",
    "install-local": "bun run build && bun run package && bash scripts/install-local.sh"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "string-width": "^8.1.0",
    "tough-cookie": "^6.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^7.0.2"
  }
}
