{
  "name": "siimit",
  "version": "0.6.1",
  "description": "A small, safe CLI for logging in to Inspire and submitting training jobs",
  "type": "module",
  "bin": {
    "siimit": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build --compile --minify --sourcemap src/index.ts --outfile dist/siimit",
    "package": "xz -9 -k -f dist/siimit",
    "install:local": "bun run scripts/install-local.ts"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "string-width": "^8.1.0",
    "tough-cookie": "^6.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
